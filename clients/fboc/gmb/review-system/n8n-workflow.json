{
  "name": "FBOC — Review Request Automation",
  "nodes": [
    {
      "id": "node-webhook-trigger",
      "name": "Webhook: New Delivery",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "fboc-review-trigger",
        "responseMode": "onReceived",
        "responseData": "firstEntryJson",
        "options": {}
      }
    },
    {
      "id": "node-wait-24h",
      "name": "Wait 24 Hours",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [460, 300],
      "parameters": {
        "resume": "timeInterval",
        "unit": "hours",
        "amount": 24
      },
      "webhookId": "wait-24h-fboc"
    },
    {
      "id": "node-send-email-1",
      "name": "Send Email 1 (Resend API)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.RESEND_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyContentType": "json",
        "jsonBody": "={\n  \"from\": \"Jocelyn at French Blooms OC <alex@xlumenx.com>\",\n  \"to\": [\"{{ $json.customer_email }}\"],\n  \"subject\": \"{{ $json.customer_name }}, your French Blooms arrangement — we'd love to hear from you\",\n  \"html\": \"<p>Hi {{ $json.customer_name }},</p><p>I hope your <strong>{{ $json.arrangement_type }}</strong> arrived beautifully on {{ $json.delivery_date }} and brought a little joy into your day — or the day of whoever was lucky enough to receive it.</p><p>At French Blooms OC, every arrangement is designed by hand, with intention, and I genuinely care that it exceeded your expectations. If it did, I'd be so grateful if you'd take two minutes to leave us a Google review. Reviews help other Orange County families and businesses find us — and they mean the world to a small, owner-operated studio like ours.</p><p><a href='https://g.page/r/FBOC-GOOGLE-REVIEW-LINK/review' style='background:#c8a96e;color:white;padding:12px 24px;text-decoration:none;border-radius:4px;display:inline-block;'>Leave a Google Review</a></p><p>If anything wasn't quite right, please reply to this email directly. I want to make it right — that's a promise.</p><p>With warmth and gratitude,<br/>Jocelyn Janz<br/>Owner, French Blooms OC<br/>📞 (949) 997-2772<br/>🌐 frenchbloomsoc.com</p>\"\n}"
      }
    },
    {
      "id": "node-send-sms-1",
      "name": "Send SMS 1 (Twilio)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 480],
      "parameters": {
        "method": "POST",
        "url": "=https://api.twilio.com/2010-04-01/Accounts/{{$env.TWILIO_ACCOUNT_SID}}/Messages.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/x-www-form-urlencoded"
            }
          ]
        },
        "sendBody": true,
        "bodyContentType": "form",
        "bodyParameters": {
          "parameters": [
            {
              "name": "From",
              "value": "+19499972772"
            },
            {
              "name": "To",
              "value": "={{ $('Webhook: New Delivery').item.json.customer_phone }}"
            },
            {
              "name": "Body",
              "value": "=Hi {{ $('Webhook: New Delivery').item.json.customer_name }}! Hope your French Blooms arrangement brought joy. 🌸 A quick Google review means the world to us: https://g.page/r/FBOC-GOOGLE-REVIEW-LINK/review — Jocelyn"
            }
          ]
        }
      }
    },
    {
      "id": "node-supabase-insert",
      "name": "Supabase: Log Review Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 300],
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/review_requests",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_ANON_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.SUPABASE_ANON_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "bodyContentType": "json",
        "jsonBody": "={\n  \"customer_name\": \"{{ $('Webhook: New Delivery').item.json.customer_name }}\",\n  \"customer_email\": \"{{ $('Webhook: New Delivery').item.json.customer_email }}\",\n  \"customer_phone\": \"{{ $('Webhook: New Delivery').item.json.customer_phone }}\",\n  \"arrangement_type\": \"{{ $('Webhook: New Delivery').item.json.arrangement_type }}\",\n  \"delivery_date\": \"{{ $('Webhook: New Delivery').item.json.delivery_date }}\",\n  \"review_received\": false,\n  \"email_1_sent\": true,\n  \"sms_1_sent\": true,\n  \"created_at\": \"{{ new Date().toISOString() }}\"\n}"
      }
    },
    {
      "id": "node-wait-4d",
      "name": "Wait 4 More Days",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1120, 300],
      "parameters": {
        "resume": "timeInterval",
        "unit": "days",
        "amount": 4
      },
      "webhookId": "wait-4d-fboc"
    },
    {
      "id": "node-check-review",
      "name": "Check: Review Received?",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1340, 300],
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/review_requests?customer_email=eq.{{ $('Webhook: New Delivery').item.json.customer_email }}&select=review_received&order=created_at.desc&limit=1",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_ANON_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.SUPABASE_ANON_KEY}}"
            }
          ]
        }
      }
    },
    {
      "id": "node-if-no-review",
      "name": "IF: No Review Yet",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1560, 300],
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json[0].review_received}}",
              "value2": false
            }
          ]
        }
      }
    },
    {
      "id": "node-send-email-2",
      "name": "Send Email 2 — Follow-Up (Resend API)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1780, 200],
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.RESEND_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyContentType": "json",
        "jsonBody": "={\n  \"from\": \"Jocelyn at French Blooms OC <alex@xlumenx.com>\",\n  \"to\": [\"{{ $('Webhook: New Delivery').item.json.customer_email }}\"],\n  \"subject\": \"Still thinking about your {{ $('Webhook: New Delivery').item.json.arrangement_type }}? Leave us a quick note\",\n  \"html\": \"<p>Hi {{ $('Webhook: New Delivery').item.json.customer_name }},</p><p>Just a gentle follow-up — I wanted to check in and make sure your <strong>{{ $('Webhook: New Delivery').item.json.arrangement_type }}</strong> from {{ $('Webhook: New Delivery').item.json.delivery_date }} brought everything you were hoping for.</p><p>If you have a spare two minutes, a Google review makes an enormous difference for French Blooms OC. As a small, owner-operated florist in Orange County, reviews are truly how new clients find us and how we grow.</p><p><a href='https://g.page/r/FBOC-GOOGLE-REVIEW-LINK/review' style='background:#c8a96e;color:white;padding:12px 24px;text-decoration:none;border-radius:4px;display:inline-block;'>Leave a Google Review</a></p><p>No pressure at all — and if there's anything I can do better next time, I genuinely want to know. Just reply here.</p><p>Thank you for choosing French Blooms OC.</p><p>Warmly,<br/>Jocelyn<br/>French Blooms OC | frenchbloomsoc.com</p>\"\n}"
      }
    },
    {
      "id": "node-no-action",
      "name": "Review Already Received — Stop",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1780, 420],
      "parameters": {}
    }
  ],
  "connections": {
    "Webhook: New Delivery": {
      "main": [
        [
          {
            "node": "Wait 24 Hours",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Wait 24 Hours": {
      "main": [
        [
          {
            "node": "Send Email 1 (Resend API)",
            "type": "main",
            "index": 0
          },
          {
            "node": "Send SMS 1 (Twilio)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Email 1 (Resend API)": {
      "main": [
        [
          {
            "node": "Supabase: Log Review Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send SMS 1 (Twilio)": {
      "main": [
        [
          {
            "node": "Supabase: Log Review Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Supabase: Log Review Request": {
      "main": [
        [
          {
            "node": "Wait 4 More Days",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Wait 4 More Days": {
      "main": [
        [
          {
            "node": "Check: Review Received?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check: Review Received?": {
      "main": [
        [
          {
            "node": "IF: No Review Yet",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF: No Review Yet": {
      "main": [
        [
          {
            "node": "Send Email 2 — Follow-Up (Resend API)",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Review Already Received — Stop",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": ""
  },
  "staticData": null,
  "meta": {
    "templateId": "fboc-review-automation-v1"
  },
  "pinData": {},
  "versionId": "1.0.0",
  "triggerCount": 0,
  "tags": [
    {
      "id": "fboc",
      "name": "French Blooms OC"
    },
    {
      "id": "review-automation",
      "name": "Review Automation"
    }
  ],
  "notes": {
    "setup": {
      "env_vars_required": [
        "RESEND_API_KEY — get from resend.com/api-keys",
        "TWILIO_ACCOUNT_SID — get from console.twilio.com",
        "TWILIO_AUTH_TOKEN — used as HTTP Basic Auth password",
        "SUPABASE_URL — e.g. https://xxxx.supabase.co",
        "SUPABASE_ANON_KEY — get from Supabase project settings"
      ],
      "supabase_table_schema": {
        "table": "review_requests",
        "schema": "bloom_engine",
        "columns": [
          "id uuid DEFAULT gen_random_uuid() PRIMARY KEY",
          "customer_name text NOT NULL",
          "customer_email text NOT NULL",
          "customer_phone text",
          "arrangement_type text",
          "delivery_date date",
          "review_received boolean DEFAULT false",
          "email_1_sent boolean DEFAULT false",
          "email_2_sent boolean DEFAULT false",
          "sms_1_sent boolean DEFAULT false",
          "created_at timestamptz DEFAULT now()"
        ]
      },
      "webhook_payload_example": {
        "customer_name": "Sarah",
        "customer_email": "sarah@example.com",
        "customer_phone": "+17145550101",
        "arrangement_type": "La Belle Spring Bouquet",
        "delivery_date": "2026-04-16"
      },
      "google_review_link": "Replace all instances of https://g.page/r/FBOC-GOOGLE-REVIEW-LINK/review with the actual GBP short review URL once the profile is live",
      "twilio_auth": "Set TWILIO_ACCOUNT_SID as the HTTP Basic Auth username and TWILIO_AUTH_TOKEN as the password in the Twilio SMS node credentials"
    }
  }
}
