# ============================================================
# BLOOM ENGINE — Local Development Environment
# ============================================================
# All secrets are managed via Doppler.
# Do NOT put real values here. This file is committed to git.
#
# To run locally:
#   doppler run --project anchor-bloom-engine --config prd -- npm run dev
#
# To pull secrets to a local .env.local (gitignored):
#   doppler secrets download --project anchor-bloom-engine --config prd --format env --no-file > .env.local
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Perplexity
PERPLEXITY_API_KEY=your-perplexity-api-key

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Bloom Engine
BLOOM_ADMIN_PASSWORD=your-bloom-admin-password
BLOOM_CLIENT_FBOC_GMB_URL=

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars

# GMB OAuth (per-client)
GMB_CLIENT_ID=your-google-oauth-client-id
GMB_CLIENT_SECRET=your-google-oauth-client-secret
GMB_REFRESH_TOKEN_FBOC=your-fboc-gmb-refresh-token
GMB_ACCOUNT_ID_FBOC=your-fboc-gmb-account-id
GMB_LOCATION_ID_FBOC=your-fboc-gmb-location-id

# App URL
NEXT_PUBLIC_APP_URL=https://cms.frenchbloomsoc.com
